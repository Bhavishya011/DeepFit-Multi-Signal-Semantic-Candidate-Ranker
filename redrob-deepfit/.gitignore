# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.ruff_cache/

# ─── Virtual envs ─────────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── IDE ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store

# ─── Large artifacts (regenerated by precompute/build_all.sh) ─────────────
artifacts/*.npz
artifacts/*.npy
artifacts/*.parquet
artifacts/models/*.onnx
artifacts/models/*.bin
# Keep config and small json committed
!config/
!artifacts/.gitkeep

# ─── Submission outputs (regenerated) ─────────────────────────────────────
*.csv
!tests/dev_set/*.csv
!sample_submission.csv

# ─── Notebooks checkpoints ────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/
wandb/

# ─── HuggingFace cache (if any) ───────────────────────────────────────────
.cache/
